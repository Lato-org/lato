  }
%&#62;
</pre>

<h4>Set a Custom Size</h4>

<p>
<%= link_to 'Example', main_app.products_path, data: { lato_action_target: 'trigger', turbo_frame: 'lato_index_default_product', action_size: 'xl' }, class: 'llm-ignore' %>
</p>

<pre>
&#60;%= link_to 'Example',
  main_app.products_path,
